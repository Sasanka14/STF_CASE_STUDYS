// Switch-Case Statement in C++ Example
#include <iostream>
using namespace std;
int main(){
    char input = 'B';
    switch(input){
        case 'A':
        cout << "You have selected option A" << endl;
        break;
        case 'B':
        cout << "You have selected option B" << endl;
        break;
        default:
        cout << "Invalid Input" << endl;
    }
    return 0;
}



